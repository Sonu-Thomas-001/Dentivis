// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("ORTHODONTIST")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patients  Patient[]
}

model Patient {
  id             String           @id @default(uuid())
  name           String
  dateOfBirth    DateTime?
  status         String           @default("ACTIVE")
  orthodontistId String
  orthodontist   User             @relation(fields: [orthodontistId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Case {
  id             String   @id @default(uuid())
  patientName    String
  patientAge     Int?
  type           String
  status         String   @default("Draft")
  scanFileUrl    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

